# ================================================================
# RAILWAY ENVIRONMENT VARIABLES TEMPLATE
# ================================================================
# SECURITY WARNING: Never commit the actual .env file to Git!
# This template shows what variables to set in Railway dashboard
# ================================================================

# Django Settings
# Generate a new SECRET_KEY with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-super-secret-key-here-GENERATE-NEW-ONE-MINIMUM-50-CHARS

# CRITICAL: Set to False in Railway production environment
DEBUG=False

# Add your Railway app domain (Railway provides this automatically)
# Example: your-app-name.up.railway.app
ALLOWED_HOSTS=your-app-name.up.railway.app,localhost

# Database Configuration
# Railway provides DATABASE_URL automatically when you add PostgreSQL
# You don't need to manually set this - Railway handles it
# DATABASE_URL=postgresql://... (auto-provided by Railway)

# Email Configuration (Optional - only if using email features)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# NOAA API Token (for OpenClimate app)
# Get your token from: https://www.ncdc.noaa.gov/cdo-web/token
NOAA_API_TOKEN=your-noaa-api-token-here

# ================================================================
# RAILWAY SETUP INSTRUCTIONS:
# ================================================================
# 1. In Railway dashboard, go to your project > Variables tab
# 2. Add each variable above (except DATABASE_URL - Railway adds this)
# 3. Railway will automatically restart your app when you save
# 4. Never commit .env files with actual values to Git!
# ================================================================